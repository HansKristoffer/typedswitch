{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConfusingVoidType": "off",
				"noExplicitAny": "warn",
				"noArrayIndexKey": "off",
				"noDocumentCookie": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useExportType": "warn"
			},
			"correctness": {
				"noEmptyPattern": "off",
				"noUnusedFunctionParameters": "warn",
				"noUnusedVariables": "warn",
				"useParseIntRadix": "off",
				"useExhaustiveDependencies": "warn",
				"useHookAtTopLevel": "off"
			},
			"performance": {
				"noDelete": "off",
				"noAccumulatingSpread": "off",
				"noImgElement": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "off",
				"noSvgWithoutTitle": "off",
				"noStaticElementInteractions": "off",
				"useMediaCaption": "off",
				"noLabelWithoutControl": "off",
				"useButtonType": "off",
				"useSemanticElements": "off",
				"useFocusableInteractive": "off",
				"useAriaPropsForRole": "off",
				"noRedundantAlt": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"attributePosition": "auto",
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 80,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none",
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"!**/prisma/generated",
			"!**/.expo",
			"!**/routeTree.gen.ts",
			"!**/components.d.ts",
			"!**/dialogs.gen.ts",
			"!**/auto-imports.d.ts",
			"!**/primevue-components.d.ts"
		]
	},
	"overrides": [
		{
			"includes": [
				"packages/utils/apiWrapper.ts",
				"packages/utils/customerIoApiV1/**/*.ts",
				"packages/utils/generateId.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
